require 'pathname'
require 'fileutils'
require 'optparse'

options = {}
cli = OptionParser.new do |parser|
  parser.on('-v', '--version VERSION', 'Open banking version e.g. fase 1, 2, 3') do |v| Pathname.new v end
  end
cli.parse!(into: options)

version = options[:version]

def clean_paths_from_file(filename)
  tempfile=File.open("file.tmp", 'w+:UTF-8')
  f=File.new(filename)

  shouldWriteLine = true

  f.each do |line|

    if (shouldWriteLine)
      tempfile<<line
    end
 
    if (line.downcase=~/^paths:/)
      shouldWriteLine = false
    end
  end
  tempfile<<"components:"
  tempfile<<"\n  schemas:"
  tempfile<<"\n  parameters:"
  tempfile<<"\n  responses:"

  f.close
  tempfile.close
  
  FileUtils.mv("file.tmp", filename)
end

pn = Pathname.new("source/swagger/parts/")

filename = pn.to_s+"_open_banking_fase"+version.to_s+"_apis_part.yml"

puts '  ├── Cleaning file ' + filename + ' from old paths'

clean_paths_from_file(filename)
